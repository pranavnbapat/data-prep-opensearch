# ---------------- Backend DEV creds ----------------
BACKEND_CORE_HOST_DEV=
BACKEND_CORE_DEV_API_USERNAME=
BACKEND_CORE_DEV_API_PASSWORD=

# ---------------- Backend PRD creds ----------------
BACKEND_CORE_HOST_PRD=
BACKEND_CORE_PRD_API_USERNAME=
BACKEND_CORE_PRD_API_PASSWORD=

# Legacy transcription endpoint (common/utils.py)
TRANSCRIBE_ENDPOINT_URL=
WHISPER_MODEL=
TRANSCRIBE_HTTP_TIMEOUT=


# =========================
# Core runtime
# =========================
# Environment selector (e.g., DEV/PRD)
ENV_MODE=
# Logging verbosity (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=
# Output root folder for stage artefacts
OUTPUT_ROOT=
# Timezone for timestamps/logs
TZ=
# Pipeline target endpoint (used by scheduler)
TARGET_URL=
# Container user ID mapping (Linux)
UID=
# Container group ID mapping (Linux)
GID=


# =========================
# Optional MySQL control plane
# =========================
MYSQL_HOST=data-prep-opensearch-mysql
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# MySQL Docker image root password
MYSQL_ROOT_PASSWORD=
# Skip timezone info during MySQL init (Docker image)
MYSQL_INITDB_SKIP_TZINFO=
# Connection timeout in seconds
MYSQL_CONNECT_TIMEOUT=10
# Fast path processes PDFs up to this page count; larger PDFs are deferred.
FAST_PIPELINE_PDF_MAX_PAGES=10
# Timeout for hosted PDF page-count probing during sync.
MYSQL_SYNC_PDFINFO_TIMEOUT=30
# Processing eligibility gates aligned with ingestion.
PROCESSING_MAX_FILE_SIZE_BYTES=1073741824
PROCESSING_MAX_PDF_PAGES=100
PROCESSING_MAX_OFFICE_PAGES=100
PROCESSING_MAX_TEXT_FILE_BYTES=5242880
PROCESSING_MAX_TEXT_CHARS=500000
PROCESSING_MAX_IMAGE_DIM_PX=10000
PROCESSING_MAX_MEDIA_DURATION_SEC=3000
PROCESSING_PROBE_TIMEOUT=30
PROCESSING_PROBE_RETRIES=3
PROCESSING_PROBE_BACKOFF_SEC=1.0
# Caps for stored processed text fields before writing current_doc_json to MySQL.
STORAGE_MAX_KO_CONTENT_FLAT_CHARS=500000
STORAGE_MAX_KO_CONTENT_FLAT_VISION_CHARS=200000
STORAGE_MAX_KO_CONTENT_FLAT_SUMMARISED_CHARS=120000
STORAGE_MAX_DESCRIPTION_LLM_CHARS=16000


# =========================
# Stage toggles
# =========================
# Run downloader stage (1=on, 0=off)
ENABLE_DOWNLOADER=
# Run enricher stage (1=on, 0=off)
ENABLE_ENRICHER=
# Run improver stage (1=on, 0=off)
ENABLE_IMPROVER=


# =========================
# Downloader behaviour
# =========================
# Page size for KO metadata API paging
DL_PAGE_SIZE=
# Thread workers for per-page processing
DL_MAX_WORKERS=
# Backend sort criteria (API-specific)
DL_SORT_CRITERIA=
# Truncate output payload
TRUNCATE_FINAL_OUTPUT=
# Write final_output file (1=yes, 0=no)
DL_WRITE_OUTPUT=


# =========================
# Incremental / reuse toggles
# =========================
# Reuse previous snapshot when source fingerprint unchanged
DL_SKIP_UNCHANGED_CONTENT=


# =========================
# HTTP timeouts (seconds)
# =========================
# Timeout for metadata API calls
DL_HTTP_TIMEOUT=
# Timeout for content API calls
CONTENT_HTTP_TIMEOUT=


# =========================
# Slow-call logging thresholds (seconds)
# =========================
# Log content fetch latency above this threshold
SLOW_CONTENT_SEC=


# =========================
# Drop logging / reporting
# =========================
# Max dropped items to print per page in logs
DROP_LOG_MAX=


# =========================
# Content flattening
# =========================
# Flattening mode for ko_content -> ko_content_flat
KO_CONTENT_MODE=


# =========================
# Enricher concurrency
# =========================
# Concurrency for URL text extraction
EXTRACTOR_MAX_WORKERS=
# Concurrency for transcription
TRANSCRIBE_MAX_WORKERS=
# Max chars passed to enricher (0=unlimited)
ENRICH_MAX_CHARS=


# =========================
# Enricher routing / feature flags
# =========================
# Router policy version (affects fingerprints)
ENRICHER_ROUTER_VERSION=
# Enable PageSense/URL extraction route
ENRICH_ENABLE_URL_EXTRACT=
# Enable platform transcription (YouTube/X/etc.) via deAPI
ENRICH_ENABLE_API_TRANSCRIBE=
# Enable hosted media transcription via RunPod service
ENRICH_ENABLE_CUSTOM_TRANSCRIBE=
# Enable vision fallback for visual content
ENRICH_ENABLE_VISION_FALLBACK=
# Resolve YouTube redirects during URL-only routing
ENABLE_URL_RESOLVE_YOUTUBE=
# Vision probe timeout for detecting visual targets (seconds)
ENRICH_VISION_PROBE_TIMEOUT=
# Probe timeout for target URL reachability (seconds)
ENRICH_PROBE_TIMEOUT=
# Probe media URLs before custom_transcribe (1=on, 0=off)
ENRICH_PROBE_MEDIA_URLS=
# Probe page URLs before pagesense (1=on, 0=off)
ENRICH_PROBE_PAGE_URLS=
# Delay between enricher records (seconds)
ENRICH_PER_RECORD_DELAY_SEC=
# Master switch for URL safety enforcement
URL_SAFETY_ENABLE=
# Optional Google Safe Browsing screening
URL_SAFETY_ENABLE_SAFE_BROWSING=
# Google Safe Browsing API key (optional)
GOOGLE_SAFE_BROWSING_API_KEY=
# Timeout for Safe Browsing API calls (seconds)
URL_SAFETY_SAFE_BROWSING_TIMEOUT=
EUF_WEBRISK_API_KEY=
EUF_URL_SCAN_STRICT=
EUF_FILE_SCAN_ENABLED=
EUF_FILE_SCAN_STRICT=
EUF_CLAMD_HOST=
EUF_CLAMD_PORT=
EUF_CLAMD_TIMEOUT=
EUF_CLAMDSCAN_BIN=
EUF_CLAMSCAN_BIN=


# =========================
# URL / PageSense extraction
# =========================
# Base URL for text extraction service
URL_CONTENT_EXTRACTOR_BASE=
# Overall extraction timeout (seconds)
EXTRACTOR_TIMEOUT=
# Retry count for extraction
EXTRACTOR_RETRIES=
# Backoff base for extraction retries
EXTRACTOR_BACKOFF=
# Minimum chars for extraction to count as success
EXTRACTOR_MIN_CHARS=
# HTTP timeout per extraction call (seconds)
EXTRACTOR_HTTP_TIMEOUT=
# Timeout for resolving redirect URLs (seconds)
URL_RESOLVE_TIMEOUT=
# PageSense retry count
ENRICH_PAGESENSE_TRIES=
# PageSense retry backoff base
ENRICH_PAGESENSE_BACKOFF=
# PageSense retry jitter (seconds)
ENRICH_PAGESENSE_JITTER=
# Optional comma-separated hints for hosted-origin detection
HOSTED_ORIGINS_HINTS=


# =========================
# deAPI transcription (platform URLs)
# =========================
# deAPI key
DEAPI_API_KEY=
# Whisper model for deAPI transcription
DEAPI_TRANSCRIBE_MODEL=
# HTTP timeout for deAPI calls (seconds)
DEAPI_HTTP_TIMEOUT=
# Poll interval while waiting for deAPI result (seconds)
DEAPI_POLL_INTERVAL_SEC=
# Maximum wait time for deAPI transcription (seconds)
DEAPI_MAX_WAIT_SEC=


# =========================
# Custom transcription service (RunPod)
# =========================
# Base URL of transcribe API
CUSTOM_TRANSCRIBE_ENDPOINT=
# Whisper model name used by the service
CUSTOM_TRANSCRIBE_MODEL=
# HTTP Basic Auth user
CUSTOM_TRANSCRIBE_USER=
# HTTP Basic Auth password
CUSTOM_TRANSCRIBE_PASSWORD=
# HTTP timeout for /transcribe calls
CUSTOM_TRANSCRIBE_HTTP_TIMEOUT=
# Retry count on failure
CUSTOM_TRANSCRIBE_RETRIES=
# Exponential backoff base for retries
CUSTOM_TRANSCRIBE_BACKOFF=
# Skip hosted videos longer than this many seconds before calling transcribe
CUSTOM_TRANSCRIBE_MAX_DURATION_SEC=
# Timeout for ffprobe-based duration probing
CUSTOM_TRANSCRIBE_DURATION_PROBE_TIMEOUT=
# Transcription retry count
ENRICH_TRANSCRIBE_TRIES=
# Transcription retry backoff base
ENRICH_TRANSCRIBE_BACKOFF=
# Transcription retry jitter (seconds)
ENRICH_TRANSCRIBE_JITTER=


# =========================
# Vision fallback
# =========================
# Base host preferred, for example: https://host:8000
# Full endpoint is also accepted for backward compatibility.
EUF_VISION_URL=
EUF_VISION_MODEL=
EUF_VISION_API_KEY=
# Timeout per vision API call (seconds)
EUF_VISION_TIMEOUT=
# Max tokens for vision response
EUF_VISION_MAX_TOKENS=
# Retry count for vision API calls
EUF_VISION_RETRIES=5
# Backoff base between vision retries (seconds)
EUF_VISION_RETRY_BASE_SEC=4.0
# Minimum spacing between vision requests (seconds)
EUF_VISION_MIN_INTERVAL_SEC=5.0
# Pages above this use map-reduce PDF flow
EUF_VISION_PDF_MAP_REDUCE_THRESHOLD=
# Pages per chunk in PDF map-reduce
EUF_VISION_PDF_CHUNK_PAGES=
# Max pages for PDF vision processing
EUF_VISION_PDF_MAX_PAGES=
# Retry count for PDF byte fetching
EUF_VISION_PDF_FETCH_RETRIES=
# Backoff for PDF fetch retries (seconds)
EUF_VISION_PDF_FETCH_BACKOFF_SEC=
# Max chunk summaries per reduce pass
EUF_VISION_REDUCE_PARTS_PER_PASS=


# =========================
# Improver (LLM) configuration
# =========================
# vLLM base URL
RUNPOD_VLLM_HOST=
# Model identifier served by vLLM
VLLM_MODEL=
# Max model context length (tokens)
VLLM_MAX_MODEL_LEN=
# Max chars passed downstream (0=unlimited)
PIPELINE_MAX_CHARS=
# vLLM auth (OpenAI-compatible)
VLLM_API_KEY=
# Max docs to process in improver (0=unlimited)
IMPROVER_MAX_DOCS=


# =========================
# Improver chunking + request limits
# =========================
# Target chunk size in tokens
IMPROVER_CHUNK_TARGET_TOK=
# Overlap between chunks (tokens)
IMPROVER_CHUNK_OVERLAP_TOK=
# Default generation cap per call (tokens)
IMPROVER_DEFAULT_NUM_PREDICT=
# Cap for "combine" calls (tokens)
IMPROVER_COMBINE_NUM_PREDICT=
# Retry attempts per doc (LLM stage)
IMPROVER_MAX_ATTEMPTS=
# Retry attempts for each metadata field generation
IMPROVER_METADATA_MAX_ATTEMPTS=
# Max chars of summary passed into metadata generation
IMPROVER_METADATA_INPUT_MAX_CHARS=
# Max chars of existing field value passed into metadata generation
IMPROVER_METADATA_EXISTING_VALUE_MAX_CHARS=
# Timeout per LLM request (seconds)
IMPROVER_PER_REQUEST_TIMEOUT=
# Delay between documents (seconds)
IMPROVER_DOC_DELAY_SEC=
